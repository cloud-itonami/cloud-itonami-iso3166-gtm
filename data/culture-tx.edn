#:culture{:id "gtm.dish.pepian", :name "Pepián", :country "GTM", :kind :dish, :summary "Thick meat stew from Guatemala, among the country's most iconic dishes, blending Spanish colonial and indigenous influences with ingredients such as gourd seeds, tomatillo, tomato and chili peppers.", :url "https://en.wikipedia.org/wiki/Pepi%C3%A1n", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.dish.kakik", :name "Kak'ik", :country "GTM", :kind :dish, :summary "Soup made from a type of turkey called chompipe, typical of Guatemalan cuisine with pre-Hispanic Maya origins; Guatemala recognised it as intangible cultural heritage in 2007.", :url "https://en.wikipedia.org/wiki/Kak%27ik", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.dish.fiambre", :name "Fiambre", :country "GTM", :kind :dish, :summary "Traditional Guatemalan salad with dozens of ingredients, served chilled, prepared and eaten yearly to celebrate the Day of the Dead and All Saints' Day.", :url "https://en.wikipedia.org/wiki/Fiambre", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.product.coffee", :name "Guatemalan coffee", :country "GTM", :kind :product, :summary "Coffee is an important element of Guatemala's economy; Guatemala became Central America's leading coffee producer by the late 19th century and was overtaken by Honduras in 2011.", :url "https://en.wikipedia.org/wiki/Coffee_production_in_Guatemala", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.craft.maya-textiles", :name "Maya textiles", :country "GTM", :kind :craft, :summary "Brightly coloured yarn-based textiles woven by the Maya people of Guatemala into capes, shirts, blouses and dresses; each village has its own distinctive pattern.", :url "https://en.wikipedia.org/wiki/Culture_of_Guatemala", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.festival.holy-week-processions", :name "Holy Week processions in Guatemala", :country "GTM", :kind :festival, :summary "Street expressions of faith during Guatemala's Semana Santa, usually organised by a hermandad, featuring religious floats and sculptures.", :url "https://en.wikipedia.org/wiki/Holy_Week_processions_in_Guatemala", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.heritage.tikal", :name "Tikal", :country "GTM", :kind :heritage, :summary "Ruin of an ancient Maya city in Guatemala's Petén Department, one of the largest archaeological sites of the pre-Columbian Maya civilisation, a UNESCO World Heritage Site since 1979.", :url "https://en.wikipedia.org/wiki/Tikal", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gtm.heritage.antigua-guatemala", :name "Antigua Guatemala", :country "GTM", :kind :heritage, :summary "Historic city in Guatemala's central highlands, capital of the Captaincy General of Guatemala from 1543 through 1773, designated a UNESCO World Heritage Site in 1979.", :url "https://en.wikipedia.org/wiki/Antigua_Guatemala", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
]
